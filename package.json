{
  "name": "@skywave226/seditor",
  "version": "2.3.3",
  "description": "老石富文本编辑器 —— 基于 TypeScript + TipTap 的经典风格所见即所得富文本编辑器，原生 JS 实现，无框架依赖，支持浏览器单文件引入",
  "type": "module",
  "main": "./index.js",
  "module": "./dist/sEditor.esm.js",
  "browser": "./dist/sEditor.esm.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": "./dist/sEditor.esm.js",
      "node": "./index.js",
      "import": "./dist/sEditor.esm.js",
      "default": "./index.js"
    },
    "./dist/sEditor.js": "./dist/sEditor.js",
    "./dist/sEditor.esm.js": "./dist/sEditor.esm.js",
    "./dist/sEditor.css": "./dist/sEditor.css",
    "./sEditor.config.js": "./sEditor.config.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/sEditor.js",
    "dist/sEditor.esm.js",
    "dist/sEditor.css",
    "index.js",
    "index.d.ts",
    "sEditor.config.js",
    "README.md",
    "USAGE.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "skywave226",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "rich-text-editor",
    "wysiwyg",
    "tiptap",
    "vanilla-js",
    "editor",
    "seditor",
    "no-react",
    "no-framework"
  ],
  "dependencies": {
    "@tiptap/core": "^2.12.0",
    "@tiptap/extension-color": "^2.12.0",
    "@tiptap/extension-highlight": "^2.12.0",
    "@tiptap/extension-image": "^2.12.0",
    "@tiptap/extension-link": "^2.12.0",
    "@tiptap/extension-placeholder": "^2.12.0",
    "@tiptap/extension-table": "^2.12.0",
    "@tiptap/extension-table-cell": "^2.12.0",
    "@tiptap/extension-table-header": "^2.12.0",
    "@tiptap/extension-table-row": "^2.12.0",
    "@tiptap/extension-text-align": "^2.12.0",
    "@tiptap/extension-text-style": "^2.12.0",
    "@tiptap/extension-underline": "^2.12.0",
    "@tiptap/pm": "^2.12.0",
    "@tiptap/starter-kit": "^2.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "autoprefixer": "^10.4.21",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
}
